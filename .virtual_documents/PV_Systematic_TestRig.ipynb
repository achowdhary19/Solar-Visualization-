# Option B — Interactive Folium map with Footprints, PV Canopies, and ZoLa overlays
# ---------------------------------------------------------------------------------
import os, json, glob
import folium
import geopandas as gpd
from folium.plugins import MiniMap, MeasureControl, Fullscreen, MousePosition

# ---- Inputs (change if your paths differ) ----
FOOTPRINTS_PATH = "footprints.geojson"
PV_CANOPY_POLY_PATH = "pv_canopy_footprints.geojson"        # optional
PV_CANOPY_CENTROIDS_PATH = "pv_canopy_centroids.geojson"    # optional
ZOLA_DIR = "DATA/zola"                                      # optional dir of many overlays
OUT_HTML = "maps/pv_overlays_map.html"

# ---- Helper to load a GeoJSON into a GeoDataFrame safely ----
def load_gdf(path):
    if not os.path.exists(path):
        return None
    try:
        gdf = gpd.read_file(path)
        if gdf is not None and len(gdf) > 0:
            return gdf
    except Exception as e:
        print("[WARN] Could not read {}: {}".format(path, e))
    return None

# ---- Load core layers ----
footprints = load_gdf(FOOTPRINTS_PATH)
pv_canopies = load_gdf(PV_CANOPY_POLY_PATH)
pv_centroids = load_gdf(PV_CANOPY_CENTROIDS_PATH)

# ---- Determine map center/bounds from whatever is available ----
def get_bounds(gdfs):
    xs = []
    for g in gdfs:
        if g is not None and len(g) > 0:
            minx, miny, maxx, maxy = g.total_bounds
            xs.append((minx, miny, maxx, maxy))
    if not xs:
        # default center on LES/East Village area
        return (-73.98, 40.724, -73.97, 40.728)
    # merge bounds
    minx = min(t[0] for t in xs)
    miny = min(t[1] for t in xs)
    maxx = max(t[2] for t in xs)
    maxy = max(t[3] for t in xs)
    return (minx, miny, maxx, maxy)

bminx, bminy, bmaxx, bmaxy = get_bounds([footprints, pv_canopies, pv_centroids])
center_lat = (bminy + bmaxy) / 2.0
center_lon = (bminx + bmaxx) / 2.0

# ---- Base map ----
m = folium.Map(
    location=[center_lat, center_lon],
    zoom_start=15,
    tiles="cartodbpositron",
    control_scale=True
)

# UI helpers
Fullscreen().add_to(m)
MiniMap(toggle_display=True, position="bottomright").add_to(m)
MeasureControl(primary_length_unit="meters").add_to(m)
MousePosition(prefix="Lat/Lon", position="bottomleft").add_to(m)

# ---- Add footprints layer ----
if footprints is not None:
    def style_foot(_):
        return {"fillColor": "#3186cc", "color": "#1f78b4", "weight": 1, "fillOpacity": 0.25}
    folium.GeoJson(
        data=json.loads(footprints.to_json()),
        name="Building Footprints",
        style_function=style_foot,
        tooltip=folium.GeoJsonTooltip(
            fields=[c for c in footprints.columns if c != "geometry"],
            aliases=[c + ": " for c in footprints.columns if c != "geometry"],
            sticky=False
        )
    ).add_to(m)
else:
    print("[INFO] Footprints not found at {} — skipping".format(FOOTPRINTS_PATH))

# ---- Add PV canopy polygons (if available) ----
if pv_canopies is not None:
    def style_pv(_):
        return {"fillColor": "#ff9900", "color": "#cc7a00", "weight": 1, "fillOpacity": 0.35}
    folium.GeoJson(
        data=json.loads(pv_canopies.to_json()),
        name="PV Canopies",
        style_function=style_pv,
        tooltip=folium.GeoJsonTooltip(
            fields=[c for c in pv_canopies.columns if c != "geometry"],
            aliases=[c + ": " for c in pv_canopies.columns if c != "geometry"],
            sticky=False
        )
    ).add_to(m)
else:
    print("[INFO] PV canopy polygons not found at {} — skipping".format(PV_CANOPY_POLY_PATH))

# ---- Add PV canopy centroids as circle markers (if available) ----
if pv_centroids is not None:
    pv_centroids_wgs84 = pv_centroids.to_crs(4326) if pv_centroids.crs and pv_centroids.crs.to_epsg() != 4326 else pv_centroids
    grp = folium.FeatureGroup(name="PV Canopy Centroids", show=False)
    for _, row in pv_centroids_wgs84.iterrows():
        geom = row.geometry
        if geom is None:
            continue
        try:
            lat = geom.y
            lon = geom.x
        except Exception:
            continue
        popup_lines = []
        for c in pv_centroids.columns:
            if c == "geometry":
                continue
            v = row.get(c)
            popup_lines.append("{}: {}".format(c, v))
        popup_txt = "<br>".join(popup_lines) if popup_lines else "PV centroid"
        folium.CircleMarker(
            location=[lat, lon],
            radius=4,
            color="#802060",
            fill=True,
            fill_opacity=0.8,
            popup=folium.Popup(popup_txt, max_width=300)
        ).add_to(grp)
    grp.add_to(m)
else:
    print("[INFO] PV canopy centroids not found at {} — skipping".format(PV_CANOPY_CENTROIDS_PATH))

# ---- Auto-add all ZoLa overlays found under DATA/zola/*.geojson ----
if os.path.isdir(ZOLA_DIR):
    zola_files = sorted(glob.glob(os.path.join(ZOLA_DIR, "*.geojson")))
    if not zola_files:
        print("[INFO] No ZoLa .geojson files found in {} — skipping overlays".format(ZOLA_DIR))
    else:
        # cycle through a simple palette
        palette = [
            "#006d2c", "#08519c", "#6a51a3", "#a63603",
            "#238b45", "#2171b5", "#807dba", "#e6550d",
            "#31a354", "#4292c6", "#bcbddc", "#fd8d3c",
        ]
        k = 0
        for fpath in zola_files:
            g = load_gdf(fpath)
            if g is None:
                continue
            color = palette[k % len(palette)]
            k += 1
            layer_name = os.path.splitext(os.path.basename(fpath))[0]
            def make_style(c):
                def _style(_):
                    return {"fillColor": c, "color": c, "weight": 1, "fillOpacity": 0.15}
                return _style
            folium.GeoJson(
                data=json.loads(g.to_json()),
                name="ZoLa: {}".format(layer_name),
                style_function=make_style(color),
                tooltip=folium.GeoJsonTooltip(
                    fields=[c for c in g.columns if c != "geometry"][:10],  # limit fields to keep tooltips readable
                    aliases=[c + ": " for c in g.columns if c != "geometry"][:10],
                    sticky=False
                )
            ).add_to(m)
else:
    print("[INFO] ZoLa dir {} not present — skipping overlays".format(ZOLA_DIR))

# ---- Fit bounds to all available data ----
m.fit_bounds([[bminy, bminx], [bmaxy, bmaxx]])

# ---- Add layer control and save ----
folium.LayerControl(collapsed=False).add_to(m)
os.makedirs(os.path.dirname(OUT_HTML), exist_ok=True)
m.save(OUT_HTML)
print("Saved interactive map:", OUT_HTML)

# Show inline (in Jupyter)
m






